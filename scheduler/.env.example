# Scheduler .env — 复制为 .env 并填写实际值
# Redis — Celery broker
REDIS_URL=redis://host.docker.internal:6380/0

# MySQL — scans cron_jobs table
DB_URL=mysql+pymysql://root:root123@host.docker.internal:3307/super_agent?charset=utf8mb4

# Super-agent internal API
SUPER_AGENT_URL=http://host.docker.internal:8001

# Must match INTERNAL_API_TOKEN in root .env (auto-generated by deploy.sh)
INTERNAL_API_TOKEN=
