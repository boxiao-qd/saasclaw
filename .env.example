# ================================================================
# Super-Agent 环境变量模板
# 复制为 .env 并填写实际值
# ================================================================

# ── 应用基础 ──────────────────────────
ROOT_PATH=/bx/api

# ── 数据库 ────────────────────────────
# 本地 Docker: mysql+aiomysql://root:root123@localhost:3307/super_agent?charset=utf8mb4
# Docker 内部: mysql+aiomysql://root:root123@mysql:3306/super_agent?charset=utf8mb4
DB_URL=mysql+aiomysql://root:root123@localhost:3307/super_agent?charset=utf8mb4

# ── Elasticsearch ─────────────────────
ES_HOSTS=["http://localhost:9201"]
ES_INDEX_PREFIX=bx-messages

# ── LLM 配置 ──────────────────────────
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEYS=["sk-your-api-key"]
DEFAULT_MODEL=gpt-4
DEFAULT_DELEGATE_MODEL=gpt-4
COMPRESS_MODEL=gpt-4
AVAILABLE_MODELS=["gpt-4"]
FALLBACK_CHAIN={"gpt-4":[]}

# ── Web 搜索 ──────────────────────────
# 留空=自动检测, bing_cn=必应中国, ddgs=DuckDuckGo(开发用)
WEB_SEARCH_BACKEND=
BING_CN_URL=https://cn.bing.com

# ── Docker 沙箱 ───────────────────────
DOCKER_SANDBOX_IMAGE=bx-sandbox:latest
DOCKER_MAX_CONTAINERS_PER_USER=3
DOCKER_MAX_GLOBAL_CONTAINERS=200
DOCKER_CONTAINER_IDLE_TIMEOUT_MINUTES=30

# ── SSE ───────────────────────────────
SSE_KEEPALIVE_INTERVAL_SECONDS=15
SSE_INGRESS_TIMEOUT_SECONDS=600

# ── 认证 ──────────────────────────────
# 生产环境务必修改为随机长字符串
JWT_SECRET=change-me-to-a-random-secret
DEBUG=false
SAAS_MODE=false

# ── Redis 缓存 ────────────────────────
# 本地 Docker: redis://localhost:6380/0
# Docker 内部: redis://redis:6379/0
REDIS_URL=redis://localhost:6380/0
REDIS_PASSWORD=
CACHE_DEFAULT_TTL=300

# ── 对象存储 ──────────────────────────
# 后端: minio(推荐) / s3 / oss / file / ""(本地文件)
OBJECT_STORAGE_BACKEND=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9002
OBJECT_STORAGE_BUCKET=super-agent
OBJECT_STORAGE_PREFIX=bx-sa
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin123
OBJECT_STORAGE_REGION=

# ── 记忆管理 ──────────────────────────
MEMORY_DISTILL_ENABLED=true
MEMORY_DISTILL_MIN_MESSAGES=4
MEMORY_DISTILL_MAX_INPUT_CHARS=8000
MEMORY_INJECTION_MAX_CHARS=500
MEMORY_INJECTION_TOP_K=10

# ── Embedding ─────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_DIM=1536

# ── 内部 API 鉴权 ─────────────────────
# 调度器 → super-agent 通信令牌，部署脚本自动生成
INTERNAL_API_TOKEN=